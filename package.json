{
  "name": "goa",
  "version": "1.0.0",
  "description": "A minimal, expressive HTTP middleware framework for Node.js",
  "type": "module",
  "main": "index.js",
  "exports": {
    ".": {
      "import": "./index.js",
      "require": "./index.cjs"
    }
  },
  "files": [
    "lib/",
    "index.js",
    "index.cjs"
  ],
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "test": "node --test --experimental-test-coverage test/*.test.js",
    "test:watch": "node --test --watch test/*.test.js",
    "test:coverage": "node --test --experimental-test-coverage test/*.test.js",
    "build": "npm run build:cjs && npm run build:esm",
    "build:esm": "mkdir -p dist && cp -r lib dist/lib && cp index.js dist/",
    "build:cjs": "mkdir -p dist && node scripts/build-cjs.js",
    "lint": "echo \"No linter configured yet\"",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "web",
    "framework",
    "middleware",
    "koa",
    "http",
    "express"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": ""
  },
  "bugs": {
    "url": ""
  },
  "homepage": "",
  "engines": {
    "node": ">=18.0.0"
  }
}
